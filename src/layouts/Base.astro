---
import "~/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Cambio — The card game of memory, deception, and luck",
  description = "Learn the rules and history of Cambio, the modern memory-and-bluff card game descended from the medieval Swedish game of Kille.",
} = Astro.props;

const nav = [
  { href: "/", label: "Home" },
  { href: "/rules", label: "Rules" },
  { href: "/example", label: "Example" },
  { href: "/cheatsheet", label: "Cheat Sheet" },
  { href: "/history", label: "History" },
];
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <header class="sticky top-0 z-30 backdrop-blur-md bg-[color-mix(in_oklab,var(--color-felt-950)_75%,transparent)] border-b border-[color-mix(in_oklab,var(--color-gold-400)_22%,transparent)] no-print">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-2">
        <a href="/" class="font-display text-base sm:text-xl tracking-[0.18em] text-[var(--color-gold-200)] hover:text-[var(--color-gold-50)] transition-colors shrink-0">
          CAMBIO
        </a>
        <ul class="flex gap-0.5 sm:gap-3 text-xs sm:text-sm">
          {nav.map((n) => {
            const active = path === n.href || (n.href !== "/" && path.startsWith(n.href));
            return (
              <li>
                <a
                  href={n.href}
                  class={`px-1.5 sm:px-3 py-1.5 rounded-md transition-colors whitespace-nowrap ${active ? "text-[var(--color-gold-50)] bg-[color-mix(in_oklab,var(--color-gold-400)_14%,transparent)]" : "text-[var(--color-ivory-dim)] hover:text-[var(--color-ivory)]"}`}
                >
                  {n.label === "Cheat Sheet" ? (
                    <>
                      <span class="sm:hidden">Cheat</span>
                      <span class="hidden sm:inline">Cheat Sheet</span>
                    </>
                  ) : (
                    n.label
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </header>

    <main class="min-h-[70vh]">
      <slot />
    </main>
  </body>
</html>
