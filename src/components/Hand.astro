---
import Card from "./Card.astro";
interface Props {
  faceDown?: boolean;
  size?: "xs" | "sm" | "md" | "lg";
  cards?: Array<{ suit: any; rank: any; faceDown?: boolean }>;
}
const { faceDown = true, size = "sm", cards } = Astro.props;
const fallback = cards ?? Array.from({ length: 4 }, () => ({ suit: "spades" as const, rank: "A" as const, faceDown }));
---
<div class="inline-grid grid-cols-2 gap-3">
  {fallback.map((c) => (
    <Card suit={c.suit} rank={c.rank} faceDown={c.faceDown ?? faceDown} size={size} />
  ))}
</div>
