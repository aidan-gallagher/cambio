---
import Base from "~/layouts/Base.astro";
import WalkThrough from "~/components/WalkThrough.tsx";
import { STEPS } from "~/components/walkthrough-script";
---

<Base
  title="Cambio — Example walkthrough"
  description="A step-by-step animated walkthrough of a single Cambio game. Use the arrow keys to advance."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-10 sm:pt-16 pb-6 sm:pb-10">
    <div class="eyebrow filigree">A guided round</div>
    <h1 class="font-display text-4xl sm:text-6xl text-[var(--color-gold-50)] mt-3 leading-tight">
      Example
    </h1>
    <p class="mt-4 text-[var(--color-ivory)]/85 max-w-2xl text-base sm:text-lg leading-relaxed">
      Walkthrough of a single game. Cards stay face-down except when a player
      is looking at one. Use the arrow keys (or the buttons) to advance.
      Click any card to peek — a learning aid only.
    </p>
    <p class="mt-3 text-[var(--color-ivory)]/70 max-w-2xl text-xs sm:text-sm leading-relaxed">
      Grid shorthand: <strong>TL</strong> = top-left,
      <strong>TR</strong> = top-right, <strong>BL</strong> = bottom-left,
      <strong>BR</strong> = bottom-right.
    </p>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 pb-24">
    <WalkThrough client:visible />
    <section class="sr-only" aria-label="Text version of the Cambio example walkthrough">
      <h2>Cambio example walkthrough steps</h2>
      <ol>
        {STEPS.map((step) => (
          <li>
            <p>{step.caption}</p>
            {step.reasoning && <p>{step.reasoning}</p>}
          </li>
        ))}
      </ol>
    </section>
  </div>
</Base>
