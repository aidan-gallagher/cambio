{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cambio",
  "compatibility_date": "2026-05-01",
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    { "pattern": "cambio-game.com", "custom_domain": true },
    { "pattern": "www.cambio-game.com", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  }
}
