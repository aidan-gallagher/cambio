---
import Base from "~/layouts/Base.astro";
import Card from "~/components/Card.astro";
---

<Base title="Cambio cheat sheet — quick reference" description="A compact Cambio cheat sheet covering card values, power cards, turn order, snap rules, and how the game ends.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-10 sm:pt-16 pb-16 sm:pb-20">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-5 sm:mb-8 no-print">
      <div>
        <div class="eyebrow filigree">Quick reference</div>
        <h1 class="font-display text-3xl sm:text-4xl text-[var(--color-gold-50)] mt-2">Cambio cheat sheet</h1>
      </div>
      <button
        onclick="window.print()"
        class="hidden sm:inline-flex px-5 py-2.5 rounded-md font-display tracking-[0.18em] text-sm border border-[color-mix(in_oklab,var(--color-gold-400)_60%,transparent)] text-[var(--color-gold-200)] hover:text-[var(--color-gold-50)] hover:border-[var(--color-gold-200)] transition-colors"
      >
        PRINT
      </button>
    </div>

    <div class="grid md:grid-cols-2 gap-4 sm:gap-6">
      <section class="rounded-xl p-4 sm:p-6" style="background: color-mix(in oklab, var(--color-felt-700) 35%, transparent); border:1px solid color-mix(in oklab, var(--color-gold-400) 25%, transparent);">
        <h2 class="font-display text-xl text-[var(--color-gold-50)] mb-3">Card values</h2>
        <ul class="space-y-1.5 text-[0.94rem] sm:text-[0.98rem]">
          <li class="flex justify-between"><span>Red King (♥ ♦)</span><span class="font-mono">−1</span></li>
          <li class="flex justify-between"><span>Joker</span><span class="font-mono">0</span></li>
          <li class="flex justify-between"><span>Ace</span><span class="font-mono">1</span></li>
          <li class="flex justify-between"><span>2 – 10</span><span class="font-mono">face value</span></li>
          <li class="flex justify-between"><span>Face cards (except Red King)</span><span class="font-mono">10</span></li>
        </ul>
      </section>

      <section class="rounded-xl p-4 sm:p-6" style="background: color-mix(in oklab, var(--color-felt-700) 35%, transparent); border:1px solid color-mix(in oklab, var(--color-gold-400) 25%, transparent);">
        <h2 class="font-display text-xl text-[var(--color-gold-50)] mb-3">Power cards</h2>
        <ul class="space-y-2 text-[0.94rem] sm:text-[0.98rem]">
          <li><strong>7 / 8</strong> — see your fate. Look at one of <em>your</em> own cards.</li>
          <li><strong>9 / 10</strong> — spy again. Look at one of <em>another player's</em> cards.</li>
          <li><strong>Jack / Queen</strong> — swap unseen. Blind-swap any two cards on the table.</li>
          <li><strong>Any King</strong> — peek and fling. Look at any one card, then swap any card with one of yours.</li>
        </ul>
        <p class="text-[var(--color-ivory-dim)] text-sm mt-3 italic">Effects fire only on discard (step 3 of the active player's turn). Snapped cards have no effect.</p>
      </section>

      <section class="rounded-xl p-4 sm:p-6" style="background: color-mix(in oklab, var(--color-felt-700) 35%, transparent); border:1px solid color-mix(in oklab, var(--color-gold-400) 25%, transparent);">
        <h2 class="font-display text-xl text-[var(--color-gold-50)] mb-3">Your turn</h2>
        <ol class="space-y-2 text-[0.94rem] sm:text-[0.98rem] list-decimal list-inside">
          <li><strong>Draw</strong> the top card of the deck.</li>
          <li><strong>Decide</strong>: keep it (swap into your grid) or not.</li>
          <li><strong>Discard</strong> your candidate face-up. The card's effect fires.</li>
        </ol>
        <p class="text-[var(--color-ivory-dim)] text-sm mt-3 italic">Or, instead, call <strong>Cambio</strong> to end the game for yourself.</p>
      </section>

      <section class="rounded-xl p-4 sm:p-6" style="background: color-mix(in oklab, var(--color-felt-700) 35%, transparent); border:1px solid color-mix(in oklab, var(--color-gold-400) 25%, transparent);">
        <h2 class="font-display text-xl text-[var(--color-gold-50)] mb-3">Snap</h2>
        <ul class="space-y-1.5 text-[0.94rem] sm:text-[0.98rem]">
          <li>Anyone can snap the top discard with a same-rank card from the table.</li>
          <li>Snap your own card → eliminate it (your grid shrinks).</li>
          <li>Snap another player's card → transfer one of yours into their slot.</li>
          <li>Wrong snap → take the card back <em>and</em> draw a penalty card.</li>
        </ul>
      </section>

      <section class="rounded-xl p-4 sm:p-6" style="background: color-mix(in oklab, var(--color-felt-700) 35%, transparent); border:1px solid color-mix(in oklab, var(--color-gold-400) 25%, transparent);">
        <h2 class="font-display text-xl text-[var(--color-gold-50)] mb-3">Game end</h2>
        <ul class="space-y-1.5 text-[0.94rem] sm:text-[0.98rem]">
          <li>Game ends when someone calls <strong>Cambio</strong>.</li>
          <li>Each remaining player takes one final turn, then everyone reveals.</li>
          <li>Lowest total wins.</li>
        </ul>
      </section>

    </div>

    <div class="mt-8 sm:mt-10 flex justify-center gap-2 no-print">
      <Card rank="JOKER" suit="joker" size="sm" rotate={-6} />
      <Card rank="K" suit="spades" size="sm" rotate={-2} />
      <Card rank="A" suit="hearts" size="sm" rotate={2} />
      <Card rank="Q" suit="diamonds" size="sm" rotate={6} />
    </div>
  </div>
</Base>
