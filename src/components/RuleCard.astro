---
import Card from "./Card.astro";
interface Props {
  title: string;
  rank?: any;
  suit?: any;
  rankAlt?: any;
  suitAlt?: any;
  value?: string;
  tagline?: string;
}
const { title, rank, suit = "spades", rankAlt, suitAlt, value, tagline } = Astro.props;
---
<div
  class="not-prose rounded-xl p-6 flex gap-6 items-start"
  style="background: linear-gradient(180deg, color-mix(in oklab, var(--color-felt-700) 60%, transparent), color-mix(in oklab, var(--color-felt-900) 70%, transparent)); border:1px solid color-mix(in oklab, var(--color-gold-400) 25%, transparent); box-shadow: 0 20px 40px -30px rgba(0,0,0,0.8) inset;"
>
  <div class="flex gap-2 shrink-0">
    {rank && <Card rank={rank} suit={suit} size="sm" tilt={false} />}
    {rankAlt && <Card rank={rankAlt} suit={suitAlt ?? "hearts"} size="sm" tilt={false} rotate={6} />}
  </div>
  <div class="min-w-0">
    <div class="flex items-baseline gap-3 mb-1 flex-wrap">
      <h3 class="font-display text-[var(--color-gold-50)] text-xl m-0">{title}</h3>
      {value && <span class="text-xs eyebrow">{value}</span>}
    </div>
    {tagline && <div class="text-[var(--color-gold-200)] italic mb-2 text-sm">{tagline}</div>}
    <div class="text-[var(--color-ivory)] leading-relaxed text-[0.98rem]">
      <slot />
    </div>
  </div>
</div>
