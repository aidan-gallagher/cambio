---
import "~/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Cambio — The card game of memory, deception, and luck",
  description = "Learn the rules and history of Cambio, the modern memory-and-bluff card game descended from the medieval Swedish game of Kille.",
} = Astro.props;

const nav = [
  { href: "/", label: "Home" },
  { href: "/rules", label: "Rules" },
  { href: "/example", label: "Example" },
  { href: "/cheatsheet", label: "Cheat Sheet" },
  { href: "/history", label: "History" },
];
const site = Astro.site ?? new URL("https://cambio-game.com");
const pathname = Astro.url.pathname === "/"
  ? "/"
  : Astro.url.pathname.endsWith("/")
    ? Astro.url.pathname
    : `${Astro.url.pathname}/`;
const path = pathname.replace(/\/$/, "") || "/";
const canonical = new URL(pathname, site).toString();
const siteUrl = new URL("/", site).toString();
const siteName = "Cambio";
const ogImage = new URL("/og.png", site).toString();
const ogType = path === "/history" ? "article" : "website";
const currentNavItem = nav.find((n) => n.href === path || (path === "/" && n.href === "/"));
const jsonLd: Array<Record<string, unknown>> = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    url: siteUrl,
    inLanguage: "en",
    description,
  },
];

if (path !== "/" && currentNavItem) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: siteUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: currentNavItem.label,
        item: canonical,
      },
    ],
  });
}

const pageSchemaByPath: Record<string, Record<string, unknown>> = {
  "/": {
    "@context": "https://schema.org",
    "@type": "Game",
    name: "Cambio",
    alternateName: ["Pablo", "Cabo"],
    url: canonical,
    image: ogImage,
    description,
    numberOfPlayers: "2+",
    gameItem: "52-card deck with jokers",
    genre: "Card game",
  },
  "/rules": {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "How to play Cambio",
    url: canonical,
    image: ogImage,
    description,
    step: [
      { "@type": "HowToStep", name: "Draw", text: "Take the top card of the deck and look at it." },
      { "@type": "HowToStep", name: "Decide", text: "Keep the new card by swapping it into your grid, or discard it." },
      { "@type": "HowToStep", name: "Discard", text: "Place your candidate face-up on the discard pile. Power-card effects fire on discard." },
    ],
  },
  "/history": {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: "A short history of Cambio",
    url: canonical,
    image: ogImage,
    description,
    inLanguage: "en",
    author: { "@type": "Organization", name: siteName },
    publisher: { "@type": "Organization", name: siteName },
  },
  "/cheatsheet": {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    url: canonical,
    image: ogImage,
    description,
  },
  "/example": {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    url: canonical,
    image: ogImage,
    description,
  },
};

if (pageSchemaByPath[path]) jsonLd.push(pageSchemaByPath[path]);
const jsonLdText = JSON.stringify(jsonLd).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0b1410" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Cambio card game: The lowest hand wins." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <script type="application/ld+json" set:html={jsonLdText} />
  </head>
  <body>
    <header class="sticky top-0 z-30 backdrop-blur-md bg-[color-mix(in_oklab,var(--color-felt-950)_75%,transparent)] border-b border-[color-mix(in_oklab,var(--color-gold-400)_22%,transparent)] no-print">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-2 relative">
        <a href="/" class="font-display text-lg sm:text-xl tracking-[0.18em] text-[var(--color-gold-200)] hover:text-[var(--color-gold-50)] transition-colors shrink-0">
          CAMBIO
        </a>

        {/* Desktop nav */}
        <ul class="hidden sm:flex gap-3 text-sm">
          {nav.map((n) => {
            const active = path === n.href || (n.href !== "/" && path.startsWith(n.href));
            return (
              <li>
                <a
                  href={n.href}
                  class={`px-3 py-1.5 rounded-md transition-colors whitespace-nowrap ${active ? "text-[var(--color-gold-50)] bg-[color-mix(in_oklab,var(--color-gold-400)_14%,transparent)]" : "text-[var(--color-ivory-dim)] hover:text-[var(--color-ivory)]"}`}
                >
                  {n.label}
                </a>
              </li>
            );
          })}
        </ul>

        {/* Mobile hamburger */}
        <button
          id="mobile-nav-toggle"
          type="button"
          class="sm:hidden inline-flex items-center justify-center w-11 h-11 -mr-2 rounded-md text-[var(--color-gold-200)] hover:text-[var(--color-gold-50)] hover:bg-[color-mix(in_oklab,var(--color-gold-400)_10%,transparent)] transition-colors"
          aria-controls="mobile-nav"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <svg class="icon-open w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" y1="7" x2="20" y2="7" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="17" x2="20" y2="17" />
          </svg>
          <svg class="icon-close hidden w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18" />
            <line x1="6" y1="18" x2="18" y2="6" />
          </svg>
        </button>

        {/* Mobile drawer */}
        <div
          id="mobile-nav"
          class="sm:hidden hidden absolute left-0 right-0 top-full z-40 bg-[var(--color-felt-900)] border-b border-[color-mix(in_oklab,var(--color-gold-400)_22%,transparent)] shadow-xl shadow-black/60"
        >
          <ul class="flex flex-col py-2 px-2">
            {nav.map((n) => {
              const active = path === n.href || (n.href !== "/" && path.startsWith(n.href));
              return (
                <li>
                  <a
                    href={n.href}
                    data-mobile-nav-link
                    class={`block px-4 py-3 rounded-md text-base transition-colors ${active ? "text-[var(--color-gold-50)] bg-[color-mix(in_oklab,var(--color-gold-400)_14%,transparent)]" : "text-[var(--color-ivory-dim)] hover:text-[var(--color-ivory)] hover:bg-[color-mix(in_oklab,var(--color-gold-400)_8%,transparent)]"}`}
                  >
                    {n.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      </nav>
    </header>

    <script is:inline>
      (function () {
        const btn = document.getElementById("mobile-nav-toggle");
        const panel = document.getElementById("mobile-nav");
        if (!btn || !panel) return;

        const iconOpen = btn.querySelector(".icon-open");
        const iconClose = btn.querySelector(".icon-close");

        function setOpen(open) {
          btn.setAttribute("aria-expanded", String(open));
          panel.classList.toggle("hidden", !open);
          if (iconOpen) iconOpen.classList.toggle("hidden", open);
          if (iconClose) iconClose.classList.toggle("hidden", !open);
        }

        btn.addEventListener("click", function (e) {
          e.stopPropagation();
          const isOpen = btn.getAttribute("aria-expanded") === "true";
          setOpen(!isOpen);
        });

        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && btn.getAttribute("aria-expanded") === "true") {
            setOpen(false);
            btn.focus();
          }
        });

        document.addEventListener("click", function (e) {
          if (btn.getAttribute("aria-expanded") !== "true") return;
          const target = e.target;
          if (target instanceof Node && !panel.contains(target) && !btn.contains(target)) {
            setOpen(false);
          }
        });

        panel.querySelectorAll("[data-mobile-nav-link]").forEach(function (link) {
          link.addEventListener("click", function () {
            setOpen(false);
          });
        });
      })();
    </script>

    <main class="min-h-[70vh]">
      <slot />
    </main>
  </body>
</html>
