---
import Base from "~/layouts/Base.astro";
import Section from "~/components/Section.astro";
import Callout from "~/components/Callout.astro";
import Card from "~/components/Card.astro";
import Hand from "~/components/Hand.astro";
import RuleCard from "~/components/RuleCard.astro";
import Toc from "~/components/Toc.astro";

const toc = [
  { id: "overview", label: "Overview" },
  { id: "components", label: "Components" },
  { id: "objective", label: "Objective" },
  { id: "setup", label: "Setup" },
  { id: "opening", label: "Opening peek" },
  { id: "turn", label: "Turn structure" },
  { id: "values", label: "Card values" },
  { id: "power", label: "Power cards" },
  { id: "snap", label: "Snap" },
  { id: "cambio", label: "Calling Cambio" },
];

const values: Array<{
  card: string;
  value: string;
  cards: Array<{ rank: string; suit: string }>;
}> = [
  { card: "Red King (♥ ♦)", value: "−1", cards: [{ rank: "K", suit: "diamonds" }, { rank: "K", suit: "hearts" }] },
  { card: "Joker", value: "0", cards: [{ rank: "JOKER", suit: "joker" }] },
  { card: "Ace", value: "1", cards: [{ rank: "A", suit: "hearts" }] },
  { card: "2 – 10", value: "Face value", cards: [{ rank: "5", suit: "diamonds" }] },
  { card: "Face cards (except Red King)", value: "10", cards: [
    { rank: "J", suit: "clubs" },
    { rank: "Q", suit: "hearts" },
    { rank: "K", suit: "spades" },
  ] },
];
---

<Base title="Cambio — Full rules">
  <div class="max-w-6xl mx-auto px-6 pt-20 pb-10">
    <div class="eyebrow filigree">The rules</div>
    <h1 class="font-display text-5xl sm:text-6xl text-[var(--color-gold-50)] mt-4 leading-tight">How to play Cambio</h1>

  </div>

  <div class="max-w-6xl mx-auto px-6 grid lg:grid-cols-[220px_1fr] gap-12">
    <aside class="hidden lg:block"><Toc items={toc} /></aside>

    <article>
      <Section id="overview" eyebrow="The shape of the game" title="Overview">
        <p>
          Cambio is a draw-and-discard game for two or more players (best with four to six).
          Each player keeps a small face-down grid of cards and tries to hold the lowest
          possible total when someone declares the game over.
        </p>
        <p>
          The game rewards memory, attention, and an instinct for when a known hand is good
          enough — and punishes the opposite of all three.
        </p>
      </Section>

      <Section id="components" eyebrow="What you'll need" title="Components">
        <ul>
          <li><strong>2 or more players</strong>, optimally <strong>4–6</strong>.</li>
          <li>An unmarked, regular <strong>52-card deck with both jokers</strong>.</li>
          <li>For every multiple of six players, add an additional deck.</li>
        </ul>
      </Section>

      <Section id="objective" eyebrow="What you're trying to do" title="Objective">
        <p>
          Hold the lowest scoring hand on the table when the game ends. The game ends as soon
          as a player calls <strong>Cambio</strong> on their turn; everyone else takes one
          final turn, all hands are revealed, and the lowest total wins.
        </p>
      </Section>

      <Section id="setup" eyebrow="Before the first card is played" title="Setup">
        <p>
          Shuffle thoroughly. Deal four cards face down to each player in a 2×2 grid. Place
          the remaining deck face-down in the centre of the table; the discard pile builds
          face-up alongside it as cards are played.
        </p>
        <p>
          Players <strong>may not</strong> rearrange the cards in their grid — once dealt,
          they stay where they are.
        </p>

        <div class="not-prose setup-table">
          <div class="seat top">
            <span class="seat-label">PLAYER 1</span>
            <div class="rot-wrap" style="width: 140px; height: 196px;">
              <div style="transform: rotate(180deg);">
                <Hand size="sm" faceDown={true} />
              </div>
            </div>
          </div>

          <div class="seat left">
            <span class="seat-label seat-label-vertical">PLAYER 2</span>
            <div class="rot-wrap" style="width: 196px; height: 140px;">
              <div style="transform: rotate(90deg);">
                <Hand size="sm" faceDown={true} />
              </div>
            </div>
          </div>

          <div class="seat center">
            <div class="cc-stack">
              <div class="deck">
                <div class="deck-card" style="top:4px;left:4px;"><Card faceDown size="sm" tilt={false} /></div>
                <div class="deck-card" style="top:2px;left:2px;"><Card faceDown size="sm" tilt={false} /></div>
                <div class="deck-card" style="top:0;left:0;"><Card faceDown size="sm" tilt={false} /></div>
              </div>
              <span class="seat-label">DECK</span>
            </div>
            <div class="cc-stack">
              <Card rank="7" suit="hearts" size="sm" tilt={false} rotate={-3} />
              <span class="seat-label">DISCARD</span>
            </div>
          </div>

          <div class="seat right">
            <div class="rot-wrap" style="width: 196px; height: 140px;">
              <div style="transform: rotate(-90deg);">
                <Hand size="sm" faceDown={true} />
              </div>
            </div>
            <span class="seat-label seat-label-vertical">PLAYER 3</span>
          </div>
        </div>
      </Section>

      <style>
        .setup-table {
          display: grid;
          grid-template-columns: auto 1fr auto;
          grid-template-areas:
            ".    top    ."
            "left center right";
          column-gap: 2.5rem;
          row-gap: 1.75rem;
          align-items: center;
          justify-items: center;
          max-width: 720px;
          margin: 3rem auto 1.5rem;
          position: relative;
          padding: 1rem;
        }
        .setup-table::before {
          content: "";
          position: absolute;
          inset: 8% 6%;
          border-radius: 50%;
          background: radial-gradient(ellipse 60% 55% at 50% 50%, color-mix(in oklab, var(--color-felt-700) 70%, transparent), transparent 70%);
          filter: blur(6px);
          z-index: -1;
        }
        .setup-table .seat { display: flex; flex-direction: column; align-items: center; gap: 1rem; position: relative; z-index: 1; }
        .setup-table .top { grid-area: top; }
        .setup-table .left { grid-area: left; flex-direction: row; gap: 0.9rem; }
        .setup-table .right { grid-area: right; flex-direction: row; gap: 0.9rem; }
        .setup-table .center { grid-area: center; display: flex; flex-direction: row; gap: 1.5rem; align-items: flex-start; }

        .rot-wrap { display: grid; place-items: center; }

        .seat-label {
          font-family: 'Cinzel', serif;
          letter-spacing: 0.32em;
          font-size: 0.68rem;
          color: var(--color-gold-200);
          opacity: 0.8;
          white-space: nowrap;
        }
        .seat-label-vertical {
          writing-mode: vertical-rl;
          letter-spacing: 0.32em;
        }

        .cc-stack { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
        .deck { position: relative; width: 68px; height: 96px; margin: 0 auto; }
        .deck-card { position: absolute; }

        @media (max-width: 700px) {
          .setup-table {
            grid-template-columns: 1fr;
            grid-template-areas:
              "top"
              "center"
              "left"
              "right";
            row-gap: 2.25rem;
          }
          .setup-table .left,
          .setup-table .right {
            flex-direction: column;
            gap: 1rem;
          }
          .seat-label-vertical {
            writing-mode: horizontal-tb;
          }
        }
      </style>

      <Section id="opening" eyebrow="The single permitted glance" title="Opening peek">
        <p>
          Before the first card is played, every player looks at their own <strong>bottom two cards</strong>.
          Once play starts, no more free peeks at your cards.
        </p>
        <p>
          Play proceeds <strong>clockwise</strong>, starting with the player to the left of
          the dealer.
        </p>
      </Section>

      <Section id="turn" eyebrow="Draw, decide, discard" title="Turn structure">
        <p>
          On your turn you briefly hold five cards — your four in the grid plus a new one — and
          you put one of those five face-up on the discard pile, leaving four cards in your grid
          for the next player. The turn breaks into three actions:
        </p>
        <div class="not-prose grid sm:grid-cols-3 gap-5 my-6">
          {[
            { n: "1", t: "Draw", b: "Take the top card of the deck and look at it." },
            { n: "2", t: "Decide", b: "Either keep the new card (swap it into your grid; the card you displace becomes your discard candidate) or don't (the card you just drew is the candidate)." },
            { n: "3", t: "Discard", b: "Place your candidate face-up on the discard pile. If it's a power card (7, 8, 9, 10, J, Q, K), its effect fires now." },
          ].map((o) => (
            <div
              class="rounded-xl p-5"
              style="background: color-mix(in oklab, var(--color-felt-700) 35%, transparent); border:1px solid color-mix(in oklab, var(--color-gold-400) 22%, transparent);"
            >
              <div class="font-display text-[var(--color-gold-400)] text-2xl mb-1">{o.n}</div>
              <div class="font-display text-[var(--color-gold-50)] mb-1.5">{o.t}</div>
              <p class="text-[var(--color-ivory)]/85 text-[0.95rem] leading-relaxed m-0">{o.b}</p>
            </div>
          ))}
        </div>
        <p>
          Or, instead of any of that, <strong>call Cambio</strong> to end the game for yourself.
          See <a href="#cambio">Calling Cambio</a> below.
        </p>
      </Section>

      <Section id="values" eyebrow="The point chart" title="Card values">
        <div class="not-prose overflow-hidden rounded-xl border border-[color-mix(in_oklab,var(--color-gold-400)_25%,transparent)]">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-[color-mix(in_oklab,var(--color-gold-400)_15%,transparent)]">
                <th class="px-4 py-3 font-display tracking-[0.15em] text-xs text-[var(--color-gold-200)]">Card</th>
                <th class="px-4 py-3 font-display tracking-[0.15em] text-xs text-[var(--color-gold-200)]">Value</th>
                <th class="px-4 py-3"></th>
              </tr>
            </thead>
            <tbody class="text-[var(--color-ivory)]">
              {values.map((v, i) => (
                <tr class={i % 2 ? "bg-[color-mix(in_oklab,var(--color-felt-700)_25%,transparent)]" : ""}>
                  <td class="px-4 py-3 font-medium">{v.card}</td>
                  <td class="px-4 py-3 font-display text-[var(--color-gold-50)] text-lg">{v.value}</td>
                  <td class="px-4 py-3">
                    <div class="flex gap-1.5 items-center">
                      {v.cards.map((c) => (
                        <Card rank={c.rank as any} suit={c.suit as any} size="xs" tilt={false} />
                      ))}
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </Section>

      <Section id="power" eyebrow="The four effects" title="Power cards">
        <p>
          Four power cards do something special when <strong>discarded by the active player</strong>
          on their turn (step 3 above). Each effect resolves before play continues. Cards added
          to the discard pile via a <a href="#snap">snap</a> have <strong>no effect</strong>.
        </p>

        <div class="not-prose space-y-5 my-8">
          <RuleCard title="Seven or Eight" rank="7" suit="diamonds" rankAlt="8" suitAlt="clubs" value="See your fate" tagline="Seven or eight — see your fate.">
            Look at one card from <strong>your own</strong> grid. Pick a face-down card,
            peek at it privately, and return it.
          </RuleCard>

          <RuleCard title="Nine or Ten" rank="9" suit="spades" rankAlt="10" suitAlt="hearts" value="Spy again" tagline="Nine or ten — spy again.">
            Look at one card from <strong>another player's</strong> grid. Pick one of their
            face-down cards, peek at it privately, and return it.
          </RuleCard>

          <RuleCard title="Jack or Queen" rank="J" suit="clubs" rankAlt="Q" suitAlt="hearts" value="Swap unseen" tagline="Jack or Queen — swap unseen.">
            <strong>Blind-swap</strong> any two cards on the table — yours, theirs, mixed.
            Neither card is revealed to anyone before or after.
          </RuleCard>

          <RuleCard title="Black or Red King" rank="K" suit="spades" rankAlt="K" suitAlt="hearts" value="Peek and fling" tagline="Any King — peek and fling.">
            Two effects, in either order: <strong>look</strong> at any one card on the table,
            and <strong>swap</strong> any card on the table with one of your own. The looked-at
            card and the swapped card don't have to be the same. Both Black and Red Kings have
            this effect.
          </RuleCard>
        </div>

        <Callout variant="tip">
          A power card's effect only fires when it's discarded by the active player on their
          turn — never when a card is snapped onto the pile. While you're mid-swap (Jack,
          Queen, or King), no other player may attempt to snap until your swap is complete.
        </Callout>
      </Section>

      <Section id="snap" eyebrow="The fastest play in the game" title="Snap">
        <p>
          At any point — except while a player is mid-swap — <strong>any player</strong> may
          <strong>snap</strong> the top card of the discard pile by slapping a card of the
          same rank from the table on top of it.
        </p>
        <h3>What a successful snap does</h3>
        <ul>
          <li>
            If you snap with one of your own cards, that card joins the discard pile and
            <strong>you do not replace it</strong>. Your grid shrinks by one.
          </li>
          <li>
            If you snap another player's card, you <strong>transfer one of your own cards
            into their grid</strong> in the empty slot you just created. Your grid shrinks;
            theirs stays the same size but gains an unknown card.
          </li>
          <li>
            <strong>A snapped card has no effect</strong>, even if it's a power card —
            effects only fire on a normal discard (step 3 of the active player's turn).
          </li>
          <li>You may never snap directly from the deck.</li>
        </ul>

        <h3>What a failed snap does</h3>
        <p>
          If you turn over a card to snap but get it wrong, the card stays where it is — and
          you draw a new face-down card from the top of the deck as a penalty, growing your
          grid by one.
        </p>


        <Callout variant="tip" title="Speed is the whole point">
          Each discarded card may be snapped <strong>at most once</strong>. If two players
          reach for it, the faster hand wins; the slower one keeps their card.
        </Callout>
      </Section>

      <Section id="cambio" eyebrow="Ending the game" title="Calling Cambio">
        <p>
          On your turn, instead of drawing, you may declare <strong>"Cambio"</strong>. You forfeit the rest of your turn. Each remaining player takes one
          last turn, then everyone reveals their hand and totals are scored.
        </p>
        <p>
          You cannot call Cambio out of turn. The call must be made before you touch the deck.
        </p>
      </Section>
    </article>
  </div>
</Base>
